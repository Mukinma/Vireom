# Runtime mode
CAMERAPI_DEBUG=false

# Required in production when CAMERAPI_DEBUG=false
# Use a long random value (at least 32 chars)
CAMERAPI_SECRET=change-me-with-a-long-random-secret

# Admin credentials
CAMERAPI_ADMIN_USER=admin
CAMERAPI_ADMIN_PASSWORD=change-me

# Comma-separated CORS origins. Examples:
# CAMERAPI_CORS_ORIGINS=https://admin.example.com,https://kiosk.example.com
# Leave empty in production to disable cross-origin access.
CAMERAPI_CORS_ORIGINS=

# Session hardening
CAMERAPI_SESSION_HTTPS_ONLY=false
CAMERAPI_SESSION_MAX_AGE_SECONDS=28800

# Disabled unless explicitly enabled for local/debug maintenance.
CAMERAPI_ENABLE_RESTART=false

# Camera and processing tuning
CAMERAPI_MAX_FPS=30
CAMERAPI_STREAM_FPS=15
CAMERAPI_PROCESS_INTERVAL_MS=200
CAMERAPI_CV_THREADS=2
CAMERAPI_CAMERA_BUFFER_SIZE=1
CAMERAPI_CAMERA_JPEG_QUALITY=80

# Biometric data encryption at rest (AES-128-CBC + HMAC-SHA256 via Fernet)
# OFF by default. Run migrate_encrypt_dataset.py BEFORE enabling.
# Requires CAMERAPI_SECRET to be set to a non-empty value.
CAMERAPI_STORAGE_ENCRYPTED=0

# Liveness / anti-spoofing (classical CV — no neural networks)
# OFF by default until calibrated with your own dataset.
# Enable with CAMERAPI_LIVENESS_ENABLED=1 after running calibrate_liveness.py.
CAMERAPI_LIVENESS_ENABLED=0
CAMERAPI_LIVENESS_BUFFER_SIZE=10
CAMERAPI_LIVENESS_T_LIVE=0.70
CAMERAPI_LIVENESS_T_SPOOF=0.30
CAMERAPI_LIVENESS_W_PASSIVE=0.5
CAMERAPI_LIVENESS_W_MOTION=0.5
CAMERAPI_LIVENESS_FFT_BAND_LOW=0.25
CAMERAPI_LIVENESS_FFT_BAND_HIGH=0.45
CAMERAPI_LIVENESS_CHALLENGE_POOL=blink,smile
CAMERAPI_LIVENESS_CHALLENGE_TIMEOUT_MS=5000
CAMERAPI_LIVENESS_CHALLENGE_MAX_RETRIES=1
